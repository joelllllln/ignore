; Engine configuration file.
; Idle Dot Shooter - Godot 4.6

config_version=5

[application]

config/name="Idle Dot Shooter"
config/description="An idle tower-defense shooter. Dots descend from the top toward your cannon line. Auto-fire, earn coins, upgrade, and survive."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://icon.svg"

[display]

window/size/viewport_width=1152
window/size/viewport_height=648
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

renderer/rendering_method="forward_plus"
environment/defaults/default_clear_color=Color(0.07, 0.08, 0.11, 1)
